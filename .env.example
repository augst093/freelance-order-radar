# Freelance Order Radar Configuration

# Telegram Bot Token (Get it from @BotFather)
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Your Telegram User ID (Get it from @userinfobot or @raw_data_bot)
# The bot will only respond to this ID and send notifications to it.
TELEGRAM_USER_ID=YOUR_TELEGRAM_USER_ID_HERE

# Scraper Interval in Minutes (default: 5)
SCAN_INTERVAL_MINUTES=2

# Gemini API Key (Optional: for context-aware AI cover letters)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE


# Minimum score (1-10) for an opportunity to trigger a notification (default: 7)
MIN_SCORE_TO_NOTIFY=7

# Maximum number of Telegram notifications sent per scan cycle (default: 5)
MAX_NOTIFICATIONS_PER_SCAN=5

# Maximum age of opportunities in minutes to notify about (default: 60)
FRESHNESS_MAX_MINUTES=60

# Database path (relative to project root or absolute path)
DATABASE_PATH=freelance_radar.db
